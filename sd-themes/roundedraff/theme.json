{
  "schema": 1,
  "id": "roundedraff",
  "name": "RoundedRaff",
  "description": "RoundedRaff layout packaged as an SD theme.",
  "inherits": "lyra",
  "metrics": {
    "topPadding": 0,
    "headerHeight": 45,
    "contentSidePadding": 20,
    "listRowHeight": 42,
    "listWithSubtitleRowHeight": 69,
    "menuRowHeight": 42,
    "menuSpacing": 6,
    "homeTopPadding": 55,
    "homeCoverHeight": 300,
    "homeCoverTileHeight": 350,
    "homeRecentBooksCount": 1,
    "homeContinueReadingInMenu": true,
    "homeMenuTopOffset": 20,
    "keyboardKeyHeight": 30,
    "keyboardKeySpacing": 10,
    "keyboardBottomKeyHeight": 30,
    "keyboardKeyCornerRadius": 10,
    "keyboardFillUnselected": true,
    "keyboardOutlineAllUnselected": true,
    "popupCornerRadius": 18,
    "popupTextBold": true,
    "popupProgressDrawOutline": true,
    "popupProgressClampPercent": true
  },
  "components": {
    "homeRecents": {
      "type": "cover-strip",
      "maxBooks": 1,
      "wrap": false,
      "drawPanel": true,
      "panelCornerRadius": 20,
      "panelInsetX": 20,
      "selectionLineWidth": 1,
      "selectionCornerRadius": 18,
      "slots": [
        {
          "book": "selected",
          "x": "center",
          "y": "center",
          "height": 300,
          "widthPercent": 60,
          "yOffset": 0,
          "selected": false,
          "title": {
            "enabled": false,
            "font": "ui12",
            "style": "bold",
            "maxLines": 2,
            "offsetY": 12
          }
        }
      ]
    },
    "homeMenu": {
      "font": "ui12",
      "style": "bold",
      "centeredText": false,
      "showIcons": false,
      "drawPanel": false,
      "selectionStyle": "pill",
      "selectionCornerRadius": 30,
      "selectionInset": 20,
      "rowPaddingX": 40,
      "textInsetX": 20
    },
    "list": {
      "font": "ui12",
      "style": "bold",
      "showIcons": false,
      "textGap": 8,
      "selectionCornerRadius": 20,
      "selectionFill": true,
      "selectionOutline": false,
      "selectedTextInverted": true,
      "rowBackgrounds": true,
      "rowSidePadding": 20,
      "textInsetX": 20,
      "selectionInsetX": 0,
      "selectionInsetY": 0,
      "titleOffsetY": 12,
      "subtitleOffsetY": 34,
      "valueOffsetY": 12,
      "subtitleValueOffsetY": 22,
      "iconOffsetY": 0
    },
    "header": {
      "font": "ui12",
      "style": "bold",
      "centeredTitle": false,
      "showDivider": false,
      "titleOffsetY": 0,
      "batteryOffsetY": 14
    },
    "buttonHints": {
      "font": "small",
      "style": "regular",
      "layout": "groups",
      "buttonWidth": 80,
      "smallButtonHeight": 15,
      "cornerRadius": 15,
      "fill": true,
      "outline": true,
      "drawEmpty": true,
      "sidePadding": 20,
      "groupGap": 10,
      "bottomMargin": 10,
      "innerPadding": 16,
      "textOffsetY": 7
    },
    "tabBar": {
      "font": "ui12",
      "style": "bold",
      "equalWidth": true,
      "selectedCornerRadius": 18,
      "selectedTextInverted": true,
      "drawDivider": true,
      "horizontalInset": 4
    }
  },
  "assets": {
    "icons": {
      "book": "icons/book.bmp",
      "book24": "icons/book24.bmp",
      "bookmark": "icons/bookmark.bmp",
      "cover": "icons/cover.bmp",
      "file24": "icons/file24.bmp",
      "folder": "icons/folder.bmp",
      "folder24": "icons/folder24.bmp",
      "hotspot": "icons/hotspot.bmp",
      "image24": "icons/image24.bmp",
      "library": "icons/library.bmp",
      "recent": "icons/recent.bmp",
      "settings": "icons/settings2.bmp",
      "text24": "icons/text24.bmp",
      "transfer": "icons/transfer.bmp",
      "wifi": "icons/wifi.bmp"
    }
  },
  "devices": {
    "x3": {
      "constraints": {
        "screenWidth": 480,
        "screenHeight": 800,
        "frontButtons": 4,
        "sideButtons": "up-down"
      }
    },
    "x4": {
      "constraints": {
        "screenWidth": 480,
        "screenHeight": 800,
        "frontButtons": 0,
        "sideButtons": "up-down"
      }
    }
  }
}
